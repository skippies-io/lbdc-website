---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import type { ConceptKey, ScreenKey } from "./_data";

interface Props {
  title: string;
  concept?: ConceptKey;
  activeScreen?: ScreenKey;
  description?: string;
}

const { title, concept, activeScreen, description } = Astro.props;

const base = import.meta.env.BASE_URL; // e.g. /lbdc-website/
const sprintRoot = `${base}reports/sprint/`;

const screens: Array<{ key: ScreenKey; name: string; href: (c: ConceptKey) => string }> = [
  { key: 'home', name: 'Homepage', href: (c) => `${sprintRoot}concepts/${c}/home/` },
  { key: 'service', name: 'Service', href: (c) => `${sprintRoot}concepts/${c}/service/` },
  { key: 'about', name: 'About', href: (c) => `${sprintRoot}concepts/${c}/about/` },
  { key: 'contact', name: 'Contact', href: (c) => `${sprintRoot}concepts/${c}/contact/` },
];

const conceptLinks: Array<{ key: ConceptKey; name: string }> = [
  { key: 'A', name: 'Concept A' },
  { key: 'B', name: 'Concept B' },
  { key: 'C', name: 'Concept C' },
  { key: 'D', name: 'Concept D' },
];
---

<BaseLayout title={title} description={description}>
  <div class="sprint" data-report>
    <header class="topbar">
      <a class="brand" href={`${sprintRoot}`}>LBDC — Design Sprint</a>
      <nav class="topnav">
        <a href={`${sprintRoot}`}>Overview</a>
        <a href={`${sprintRoot}compare/`}>Comparison</a>
        <a href={`${sprintRoot}scorecard/`}>Scorecard</a>
      </nav>
    </header>

    <div class="shell">
      <aside class="sidebar">
        <div class="sbSection">
          <div class="sbTitle">Concepts</div>
          <div class="sbLinks">
            {conceptLinks.map((c) => (
              <a class:list={["sbLink", concept === c.key && "active"]} href={`${sprintRoot}concepts/${c.key}/home/`}>{c.name}</a>
            ))}
          </div>
        </div>

        {concept && (
          <div class="sbSection">
            <div class="sbTitle">Screens</div>
            <div class="sbLinks">
              {screens.map((s) => (
                <a class:list={["sbLink", activeScreen === s.key && "active"]} href={s.href(concept)}>{s.name}</a>
              ))}
            </div>
          </div>
        )}

        <div class="sbSection">
          <div class="sbTitle">Notes</div>
          <div class="sbText">
            This report is intentionally <strong>light-canvas</strong> and prioritises readability.
          </div>
        </div>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </div>

  <style>
    /* Report pages must be readable regardless of site theme tokens */
    :global(body){background:#ffffff !important;color:#111111 !important;}

    .sprint{min-height:100vh;}
    .topbar{display:flex;justify-content:space-between;align-items:center;gap:16px;padding:18px 20px;border-bottom:1px solid rgba(0,0,0,.10);position:sticky;top:0;background:rgba(255,255,255,.92);backdrop-filter: blur(8px);z-index:10;}
    .brand{font-weight:700;letter-spacing:-0.01em;}
    .topnav{display:flex;gap:14px;flex-wrap:wrap;}
    .topnav a{padding:8px 10px;border-radius:999px;border:1px solid rgba(0,0,0,.12);}
    .topnav a:hover{border-color:rgba(0,0,0,.25)}

    .shell{display:grid;grid-template-columns:260px 1fr;}
    .sidebar{border-right:1px solid rgba(0,0,0,.10);padding:18px 14px 24px;position:sticky;top:68px;height:calc(100vh - 68px);overflow:auto;}
    .content{padding:30px 22px 80px;max-width:1050px;}

    .sbSection{margin-bottom:18px;}
    .sbTitle{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:rgba(0,0,0,.55);margin-bottom:10px;}
    .sbLinks{display:flex;flex-direction:column;gap:8px;}
    .sbLink{padding:10px 12px;border-radius:12px;border:1px solid rgba(0,0,0,.10);}
    .sbLink.active{border-color:rgba(0,0,0,.32);background:rgba(0,0,0,.03)}
    .sbText{font-size:13px;line-height:1.55;color:rgba(0,0,0,.72)}

    @media (max-width: 980px){
      .shell{grid-template-columns:1fr;}
      .sidebar{position:relative;top:0;height:auto;border-right:0;border-bottom:1px solid rgba(0,0,0,.10)}
    }
  </style>
</BaseLayout>
