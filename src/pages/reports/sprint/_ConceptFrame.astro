---
import type { ConceptKey, ScreenKey } from './_data';
import { conceptCssVars } from './_conceptStyles';

interface Props {
  concept: ConceptKey;
  screen: ScreenKey;
  title: string;
  subtitle?: string;
}

const { concept, screen, title, subtitle } = Astro.props;
const vars = conceptCssVars(concept);

const style = Object.entries(vars)
  .map(([k, v]) => `${k}:${v}`)
  .join(';');
---

<section class="frame" style={style}>
  <header class="head">
    <div class="badge">Concept {concept}</div>
    <h1>{title}</h1>
    {subtitle && <p class="sub">{subtitle}</p>}

    <div class="bar">
      <a class="cta" href="#">Get in touch</a>
      <div class="crumb">Screen: <strong>{screen}</strong></div>
    </div>
  </header>

  <div class="body">
    <slot />
  </div>

  <footer class="foot">
    <div class="fine">LBDC — concept mock (for evaluation only)</div>
    <div class="fine">Accent used sparingly • focus visible • clean hierarchy</div>
  </footer>

  <style>
    .frame{border:1px solid rgba(0,0,0,.10);border-radius:18px;overflow:hidden;background:var(--c-canvas);color:var(--c-ink)}
    .head{padding:22px 22px 16px;border-bottom:1px solid var(--c-border);background:linear-gradient(180deg, var(--c-surface), var(--c-canvas));}
    .badge{display:inline-block;font-size:12px;letter-spacing:.12em;text-transform:uppercase;border:1px solid var(--c-border);border-radius:999px;padding:6px 10px;color:rgba(0,0,0,.62);background:rgba(255,255,255,.65)}
    h1{margin:10px 0 10px;font-size:40px;line-height:1.08;letter-spacing:-0.02em}
    .sub{margin:0;max-width:75ch;line-height:1.6;color:rgba(0,0,0,.72)}

    .bar{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;}
    .cta{display:inline-block;background:var(--c-accent);color:#fff;padding:10px 14px;border-radius:999px;text-decoration:none;border:1px solid rgba(0,0,0,.10)}
    .cta:hover{background:var(--c-accentHover)}
    .crumb{font-size:13px;color:rgba(0,0,0,.65)}

    .body{padding:22px;}
    .foot{display:flex;justify-content:space-between;gap:10px;padding:12px 18px;border-top:1px solid var(--c-border);background:rgba(255,255,255,.55)}
    .fine{font-size:12px;color:rgba(0,0,0,.55)}

    /* concept-specific nuance */
    :global(html[data-concept='A'] h1){letter-spacing:-0.03em}
    :global(html[data-concept='D'] h1){font-size:46px}

    @media (max-width: 520px){
      h1{font-size:34px}
      .bar{flex-direction:column;align-items:flex-start}
    }
  </style>
</section>
