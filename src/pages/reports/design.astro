---
import BaseLayout from "../../layouts/BaseLayout.astro";

const palettes = [
  {
    key: "A",
    name: "Trust + premium editorial (MetaLab-ish)",
    tokens: {
      Ink: "#1F2527",
      Canvas: "#FAFAF8",
      Surface: "#FFFFFF",
      Border: "#E6E7E8",
      Accent: "#2F6F73",
      "Accent hover": "#25585B",
    },
    image: "/reports/palettes/palette-A.png",
    intent: "Restrained monochrome base with a subtle teal/steel accent. Premium + calm + trustworthy.",
  },
  {
    key: "B",
    name: "Modern finance / confident blue",
    tokens: {
      Ink: "#111827",
      Canvas: "#F8FAFC",
      Surface: "#FFFFFF",
      Border: "#E5E7EB",
      Accent: "#1D4ED8",
      "Accent soft": "#DBEAFE",
    },
    image: "/reports/palettes/palette-B.png",
    intent: "Crisp, modern, high-trust blue. Reads ‘enterprise’ and very clean on a white canvas.",
  },
  {
    key: "C",
    name: "Warm premium (lighter)",
    tokens: {
      Ink: "#1E2426",
      Canvas: "#FBFAF7",
      Surface: "#FFFFFF",
      Border: "#E7E2D8",
      Accent: "#B8894A",
      "Accent soft": "#F3E9DD",
    },
    image: "/reports/palettes/palette-C.png",
    intent: "A lighter, more restrained warmth. A hint of ‘luxury’ without leaning brown.",
  },
];

const logo = {
  dark: "#2E3538",
  light: "#FFFFFF",
};
---

<BaseLayout title="Design UI/UX Sprint Report — LBDC">
  <main class="report">
    <header class="hero">
      <div class="kicker">Design Sprint Report</div>
      <h1>UI/UX Direction — LBDC Website Rewrite</h1>
      <p class="lede">
        A concise, all-in-one report covering the current foundation UI, key UX decisions, and the three colour palette options.
      </p>

      <div class="meta">
        <div><span>Project</span>LBDC Website Redesign</div>
        <div><span>Scope</span>Foundation UI + palette directions</div>
        <div><span>Decision needed</span>Pick default palette (A vs B)</div>
      </div>
    </header>

    <section class="section">
      <h2>1) Executive summary</h2>
      <div class="callout">
        <p><strong>Where we are:</strong> a homepage foundation is live (layout + tokens + accessibility baseline).</p>
        <p><strong>What’s pending:</strong> final copy, contact form flow, and selecting the default colour direction.</p>
        <p><strong>Recommendation:</strong> default to <strong>Palette A</strong>; keep Palette B as the “more corporate trust” fallback.</p>
      </div>
    </section>

    <section class="section">
      <h2>2) Current UI foundation (what’s implemented)</h2>
      <div class="two-col">
        <div class="card">
          <h3>Homepage structure</h3>
          <ul class="small">
            <li>Sticky nav with primary CTA (“Get in touch”)</li>
            <li>Hero + proof line + services grid</li>
            <li>Clear CTA band + minimal footer</li>
            <li>Responsive layout (mobile-first)</li>
          </ul>
        </div>
        <div class="card">
          <h3>UX / accessibility baseline</h3>
          <ul class="small">
            <li>Visible <code>:focus-visible</code> ring for keyboard navigation</li>
            <li>High-contrast, restrained UI style (no heavy effects)</li>
            <li>Design tokens centralised in <code>src/styles/tokens.css</code></li>
          </ul>
        </div>
      </div>

      <div class="shots">
        <figure class="shot">
          <figcaption>Mobile (375px)</figcaption>
          <img src="/reports/screens/homepage-375.jpg" alt="Homepage mobile screenshot" loading="lazy" />
        </figure>
        <figure class="shot">
          <figcaption>Desktop (1280px)</figcaption>
          <img src="/reports/screens/homepage-1280.jpg" alt="Homepage desktop screenshot" loading="lazy" />
        </figure>
      </div>
    </section>

    <section class="section">
      <h2>3) Brand anchor (from the logo)</h2>
      <div class="two-col">
        <div class="card">
          <h3>Primary brand pair</h3>
          <div class="swatches">
            <div class="swatch dark" style={`background:${logo.dark}`}>
              <div class="swatchLabel">Logo dark<br />{logo.dark}</div>
            </div>
            <div class="swatch" style={`background:${logo.light}`}>
              <div class="swatchLabel">Logo light<br />{logo.light}</div>
            </div>
          </div>
          <p class="small">
            The logo is intentionally minimal and confident. The site should feel the same: calm, precise, modern.
          </p>
        </div>

        <div class="card">
          <h3>How we should use colour</h3>
          <ul class="small">
            <li><strong>Neutrals first:</strong> hierarchy and whitespace do the work.</li>
            <li><strong>Accent is semantic:</strong> CTA + link + selected states.</li>
            <li><strong>Consistency:</strong> borders/hairlines before shadows.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>4) Palette options</h2>
      <div class="paletteGrid">
        {palettes.map((p) => (
          <article class="paletteCard">
            <div class="paletteHeader">
              <div class={`badge ${p.key === 'A' ? 'badgeBest' : ''}`}>Palette {p.key}{p.key === 'A' ? ' (recommended)' : ''}</div>
              <h3>{p.name}</h3>
              <p class="small">{p.intent}</p>
            </div>

            <div class="paletteImgWrap">
              <img src={p.image} alt={`Palette ${p.key} swatches`} loading="lazy" />
            </div>

            <div class="tokens">
              <h4>Tokens</h4>
              <div class="tokenRows">
                {Object.entries(p.tokens).map(([k, v]) => (
                  <div class="tokenRow">
                    <div class="tokenKey">{k}</div>
                    <div class="tokenVal">
                      <span class="dot" style={`background:${v}`} />
                      <code>{v}</code>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="callout" style="margin-top:18px">
        <p>
          Next, we’ll implement the <strong>theme switcher</strong> (Issue #10) so you can test A/B/C live via <code>?theme=</code>.
        </p>
      </div>
    </section>

    <section class="section">
      <h2>5) Next steps / open work</h2>
      <ol>
        <li><strong>Pick default palette:</strong> A vs B.</li>
        <li>Implement Issue #10 (theme switcher: A/B/C toggle).</li>
        <li>Copy pass: finalise hero + service pillars + proof line wording.</li>
        <li>Contact: form submission + spam protection (Issue #7).</li>
      </ol>

      <div class="links">
        <a href="/reports/palette/">(Legacy) Palette-only report</a>
        <a href="https://github.com/skippies-io/lbdc-website/issues/10" target="_blank" rel="noreferrer">Issue #10 — Theme switcher</a>
      </div>
    </section>
  </main>

  <style>
    /* Force report readability regardless of site theme tokens */
    :global(body){background:#ffffff !important;color:#111111 !important;}

    .report{max-width:1120px;margin:0 auto;padding:52px 20px 90px;}
    .kicker{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:rgba(0,0,0,.60);}
    h1{margin:10px 0 12px;font-size:46px;line-height:1.08;letter-spacing:-0.02em;color:#111;}
    .lede{max-width:75ch;font-size:18px;line-height:1.65;color:rgba(0,0,0,.82);}

    .meta{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:18px;}
    .meta div{border:1px solid rgba(0,0,0,.10);border-radius:14px;padding:12px 14px;background:rgba(255,255,255,.9);}
    .meta span{display:block;font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:rgba(0,0,0,.55);margin-bottom:6px;}

    .section{margin-top:44px;}
    h2{font-size:22px;margin:0 0 12px;letter-spacing:-0.01em;color:#111;}
    h3{font-size:18px;margin:0 0 8px;color:#111;}
    h4{font-size:13px;margin:0 0 8px;color:rgba(0,0,0,.72);text-transform:uppercase;letter-spacing:.12em;}
    ul,ol{margin:0;padding-left:20px;}
    li{margin:8px 0;color:rgba(0,0,0,.86)}

    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
    .card{border:1px solid rgba(0,0,0,.10);border-radius:16px;padding:16px 16px 14px;background:#fff;}

    .shots{display:grid;grid-template-columns:1fr;gap:16px;margin-top:18px;}
    .shot{border:1px solid rgba(0,0,0,.10);border-radius:18px;background:#fff;padding:14px;}
    .shot figcaption{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:rgba(0,0,0,.55);margin-bottom:10px;}
    .shot img{width:100%;height:auto;border-radius:12px;border:1px solid rgba(0,0,0,.08)}

    .swatches{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:10px;}
    .swatch{border-radius:14px;min-height:120px;position:relative;overflow:hidden;border:1px solid rgba(0,0,0,.10);}
    .swatch.dark{border-color:rgba(0,0,0,.18)}
    .swatchLabel{position:absolute;left:10px;top:10px;font-size:13px;line-height:1.25;padding:8px 10px;border-radius:12px;background:rgba(255,255,255,.86);border:1px solid rgba(0,0,0,.08)}

    .paletteGrid{display:grid;grid-template-columns:1fr;gap:18px;}
    .paletteCard{border:1px solid rgba(0,0,0,.10);border-radius:18px;overflow:hidden;background:#fff;}
    .paletteHeader{padding:16px 16px 0;}
    .badge{display:inline-block;font-size:12px;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(0,0,0,.14);border-radius:999px;padding:6px 10px;color:rgba(0,0,0,.65)}
    .badgeBest{border-color:rgba(47,111,115,.45); color:#25585B;}
    .paletteImgWrap{padding:14px 16px 0;}
    .paletteImgWrap img{width:100%;height:auto;border-radius:14px;border:1px solid rgba(0,0,0,.08)}
    .tokens{padding:14px 16px 18px;}
    .tokenRows{display:grid;grid-template-columns:1fr 1fr;gap:10px 16px;}
    .tokenRow{display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(0,0,0,.06);padding-top:10px;}
    .tokenKey{color:rgba(0,0,0,.72);font-size:14px;}
    .tokenVal{display:flex;gap:10px;align-items:center;}
    .dot{width:14px;height:14px;border-radius:999px;border:1px solid rgba(0,0,0,.18);display:inline-block;}
    code{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-size:12px;color:#111;}

    .callout{border:1px solid rgba(0,0,0,.10);border-radius:16px;padding:16px;background:rgba(250,250,248,.85)}
    .small{color:rgba(0,0,0,.72);font-size:14px;line-height:1.55;}

    .links{display:flex;flex-wrap:wrap;gap:10px;margin-top:14px;}
    .links a{display:inline-block;border:1px solid rgba(0,0,0,.14);border-radius:999px;padding:10px 14px;text-decoration:none;color:rgba(0,0,0,.78);}
    .links a:hover{border-color:rgba(0,0,0,.28)}

    @media (min-width: 900px){
      .paletteGrid{grid-template-columns:1fr 1fr 1fr;}
      .paletteCard{display:flex;flex-direction:column;}
      .tokenRows{grid-template-columns:1fr;}
      h1{font-size:56px;}
      .shots{grid-template-columns:1fr 1fr;}
    }

    @media (max-width: 860px){
      .two-col{grid-template-columns:1fr;}
      .meta{grid-template-columns:1fr;}
    }
  </style>
</BaseLayout>
