---
/**
 * Services — LBDC V1
 */
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Services"
  description="Product management, digital transformation, and online banking consulting services from LeRoy Barnes — LBDC."
>

  <!-- PAGE HEADER ─────────────────────────────────────────────── -->
  <section class="page-hero section">
    <div class="label" data-enter="0">Services</div>
    <h1 class="page-hero__h1" data-enter="1">Digital expertise,<br>delivered directly.</h1>
    <p class="page-hero__sub" data-enter="2">
      LBDC specialises in three interrelated disciplines — product management,
      digital transformation, and online banking &amp; payments. Most engagements
      draw on all three.
    </p>
  </section>

  <!-- SERVICE 01 ──────────────────────────────────────────────── -->
  <section class="section svc-detail" id="product-management">
    <div class="svc-detail__inner" data-reveal>
      <div class="svc-detail__meta">
        <div class="svc-num">01</div>
        <h2 class="svc-detail__title">Product Management<br>&amp; Strategy</h2>
        <a class="btn btn--primary" href="contact/">Enquire →</a>
      </div>
      <div class="svc-detail__body">
        <p class="svc-detail__lead">
          Great products don't emerge from slide decks. They emerge from
          teams that know what to build, in which order, and why — and
          have the tools to stay aligned when conditions change.
        </p>
        <div class="svc-items">
          <div class="svc-item">
            <h3>Roadmapping &amp; OKRs</h3>
            <p>Translate strategic intent into a prioritised product roadmap backed by Objectives and Key Results that teams actually use.</p>
          </div>
          <div class="svc-item">
            <h3>Discovery &amp; Prioritisation</h3>
            <p>Structured frameworks for identifying and validating the highest-value opportunities — avoiding the feature factory trap.</p>
          </div>
          <div class="svc-item">
            <h3>Stakeholder Alignment</h3>
            <p>Facilitation and governance structures that keep executives, product teams, and engineering in sync through every sprint.</p>
          </div>
          <div class="svc-item">
            <h3>Product Operating Model</h3>
            <p>Define roles, rituals, and decision rights so product leadership can scale without losing coherence.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 02 ──────────────────────────────────────────────── -->
  <section class="section svc-detail" id="digital-transformation">
    <div class="svc-detail__inner" data-reveal>
      <div class="svc-detail__meta">
        <div class="svc-num">02</div>
        <h2 class="svc-detail__title">Digital<br>Transformation</h2>
        <a class="btn btn--primary" href="contact/">Enquire →</a>
      </div>
      <div class="svc-detail__body">
        <p class="svc-detail__lead">
          Transformation is measured in shipped product, not in strategy
          documents. LeRoy has led the shift from quarterly to weekly
          delivery cadences at institutions managing hundreds of millions
          in product P&amp;L.
        </p>
        <div class="svc-items">
          <div class="svc-item">
            <h3>Delivery Cadence Acceleration</h3>
            <p>Diagnose deployment bottlenecks and restructure the operating model to ship faster — reliably, not just once.</p>
          </div>
          <div class="svc-item">
            <h3>Platform Modernisation</h3>
            <p>Migration strategy and execution support for legacy systems — cloud-readiness, API-first design, and team enablement.</p>
          </div>
          <div class="svc-item">
            <h3>Cross-functional Team Design</h3>
            <p>Reorganise around products and value streams, not functional silos. Define teams, charters, and accountability structures.</p>
          </div>
          <div class="svc-item">
            <h3>DevOps &amp; Agile Masterclasses</h3>
            <p>Practical coaching sessions on DevOps, cloud platforms, and Agile delivery — tailored for leadership teams and practitioners.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE 03 ──────────────────────────────────────────────── -->
  <section class="section svc-detail" id="banking-payments">
    <div class="svc-detail__inner" data-reveal>
      <div class="svc-detail__meta">
        <div class="svc-num">03</div>
        <h2 class="svc-detail__title">Online Banking &amp;<br>Digital Payments</h2>
        <a class="btn btn--primary" href="contact/">Enquire →</a>
      </div>
      <div class="svc-detail__body">
        <p class="svc-detail__lead">
          From launching mobile banking apps to integrating payment gateways
          across ten African markets, LeRoy brings hands-on fintech product
          experience to every engagement — not just advisory distance.
        </p>
        <div class="svc-items">
          <div class="svc-item">
            <h3>Mobile Banking Product Design</h3>
            <p>End-to-end product ownership for retail and business banking apps — from discovery through launch and iteration.</p>
          </div>
          <div class="svc-item">
            <h3>Payment Gateway Integration</h3>
            <p>Card, mobile money, and USSD payment rail integration — including Mastercard, Western Union®, and local African gateways.</p>
          </div>
          <div class="svc-item">
            <h3>Pan-African Fintech Expansion</h3>
            <p>Go-to-market strategy and product localisation for digital financial services across multiple African regulatory environments.</p>
          </div>
          <div class="svc-item">
            <h3>Insurance Digital Products</h3>
            <p>Super App design, USSD micro-insurance products, and embedded insurance — drawing on experience from APA Insurance in Nairobi.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ENGAGEMENT MODEL ────────────────────────────────────────── -->
  <section class="section engage">
    <div class="section__header" data-reveal>
      <div class="label">How engagements work</div>
      <h2>Flexible to your context</h2>
    </div>
    <div class="engage__grid">
      <div class="engage__item" data-reveal>
        <h3>Retained Advisory</h3>
        <p>Ongoing monthly engagement — strategy reviews, product guidance, and a senior sounding board on demand.</p>
      </div>
      <div class="engage__item" data-reveal>
        <h3>Embedded Sprint</h3>
        <p>A focused 4–12 week engagement to solve a specific challenge — delivery cadence, roadmap, or product launch.</p>
      </div>
      <div class="engage__item" data-reveal>
        <h3>Fractional CPO</h3>
        <p>Part-time Chief Product Officer — for organisations that need senior product leadership without a full-time hire.</p>
      </div>
    </div>
  </section>

  <!-- CTA ────────────────────────────────────────────────────── -->
  <section class="section cta-band">
    <div class="cta-band__inner" data-reveal>
      <div class="label">Ready to start?</div>
      <h2>Tell LeRoy what<br>you're working on.</h2>
      <p class="cta-band__sub">
        Every engagement starts with a conversation.
        No pitch, no deck — just a direct discussion about your challenge.
      </p>
      <a class="btn btn--accent btn--lg" href="contact/">Get in touch →</a>
    </div>
  </section>

</SiteLayout>

<style>
  /* ── Page hero ────────────────────────────────────────────────── */
  .page-hero { border-top: none; }
  .page-hero__h1 {
    font-size: var(--da-display);
    font-weight: 700;
    letter-spacing: var(--da-track-tight);
    line-height: var(--da-lead-tight);
    margin-bottom: 24px;
    max-width: 20ch;
  }
  .page-hero__sub {
    font-size: var(--da-body-lg);
    color: var(--da-ink-muted);
    max-width: 60ch;
    line-height: 1.6;
  }

  /* ── Service detail layout ────────────────────────────────────── */
  .svc-detail__inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--da-gap);
    align-items: start;
  }
  .svc-detail__meta {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .svc-num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--da-ink-faint);
  }
  .svc-detail__title {
    font-size: var(--da-h2);
    font-weight: 700;
    letter-spacing: var(--da-track-head);
    line-height: 1.1;
  }
  .svc-detail__lead {
    font-size: var(--da-body-lg);
    color: var(--da-ink-muted);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: var(--da-gap);
    padding-bottom: var(--da-gap);
    border-bottom: 1px solid var(--da-line);
  }

  /* Service sub-items */
  .svc-items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .svc-item {
    padding: 28px 28px 28px 0;
    border-right: 1px solid var(--da-line);
    border-bottom: 1px solid var(--da-line);
  }
  .svc-item:nth-child(even) { border-right: 0; padding-right: 0; padding-left: 28px; }
  .svc-item:nth-last-child(-n+2) { border-bottom: 0; }
  .svc-item h3 {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: var(--da-track-head);
  }
  .svc-item p {
    font-size: 14px;
    color: var(--da-ink-muted);
    line-height: 1.6;
  }

  /* ── Engagement model ─────────────────────────────────────────── */
  .engage__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .engage__item {
    padding: 32px 32px 32px 0;
    border-right: 1px solid var(--da-line);
  }
  .engage__item:last-child { border-right: 0; padding-right: 0; }
  .engage__item:not(:first-child) { padding-left: 32px; }
  .engage__item h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; }
  .engage__item p { font-size: 14px; color: var(--da-ink-muted); line-height: 1.6; }

  /* ── CTA band ─────────────────────────────────────────────────── */
  .cta-band { background: var(--da-ink); }
  .cta-band .label { color: rgba(255,255,255,0.45); }
  .cta-band__inner h2 {
    font-size: var(--da-h2);
    font-weight: 700;
    letter-spacing: var(--da-track-head);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 16px;
  }
  .cta-band__sub {
    font-size: var(--da-body);
    color: rgba(255,255,255,0.6);
    max-width: 50ch;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .svc-detail__inner { grid-template-columns: 1fr; }
    .svc-detail__meta { position: static; }
    .svc-items { grid-template-columns: 1fr; }
    .svc-item { border-right: 0; padding: 24px 0; }
    .svc-item:nth-child(even) { padding-left: 0; }
    .svc-item:nth-last-child(-n+2) { border-bottom: 1px solid var(--da-line); }
    .svc-item:last-child { border-bottom: 0; }
    .engage__grid { grid-template-columns: 1fr; }
    .engage__item { border-right: 0; border-bottom: 1px solid var(--da-line); padding: 24px 0; }
    .engage__item:not(:first-child) { padding-left: 0; }
    .engage__item:last-child { border-bottom: 0; }
  }
</style>
