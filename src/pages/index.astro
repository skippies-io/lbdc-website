---
/**
 * Home — LBDC V1
 * Design: Concept A (clean light, teal accent)
 */
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="Home"
  description="LBDC is an independent consulting practice specialising in product management, digital transformation, and online banking — serving organisations across Africa."
>

  <!-- HERO ────────────────────────────────────────────────────── -->
  <section class="hero section">
    <div class="hero__label label" data-enter="0">Product Management · Digital Transformation</div>
    <h1 class="hero__h1" data-enter="1">
      From digital vision<br>to business value.
    </h1>
    <p class="hero__sub" data-enter="2">
      LeRoy Barnes is an independent consultant helping organisations turn
      product strategy into shipped digital platforms — across banking,
      payments, and insurance.
    </p>
    <div class="hero__actions" data-enter="3">
      <a class="btn btn--primary" href="contact/">Get in touch</a>
      <a class="btn btn--ghost" href="services/">See services →</a>
    </div>

    <!-- Proof ribbon -->
    <div class="proof" aria-label="Track record highlights" data-enter="4">
      <div class="proof__item">
        <span class="proof__num">10</span>
        <span class="proof__text">country pan-African<br>payments platform</span>
      </div>
      <div class="proof__div" aria-hidden="true"></div>
      <div class="proof__item">
        <span class="proof__num">13×</span>
        <span class="proof__text">faster delivery cadence<br>achieved at Absa</span>
      </div>
      <div class="proof__div" aria-hidden="true"></div>
      <div class="proof__item">
        <span class="proof__num">+50%</span>
        <span class="proof__text">user satisfaction<br>improvement delivered</span>
      </div>
      <div class="proof__div" aria-hidden="true"></div>
      <div class="proof__item">
        <span class="proof__num">R320m</span>
        <span class="proof__text">P&amp;L responsibility<br>held at Absa Group</span>
      </div>
    </div>
  </section>

  <!-- SERVICES PREVIEW ─────────────────────────────────────────── -->
  <section class="section services">
    <div class="section__header" data-reveal>
      <div class="label">What he does</div>
      <h2>Three ways to work<br>with LeRoy</h2>
    </div>

    <div class="services__grid">
      <article class="svc" data-reveal>
        <div class="svc__num">01</div>
        <h3 class="svc__title">Product Management &amp; Strategy</h3>
        <p class="svc__body">
          Roadmapping, OKRs, and prioritisation frameworks that align
          digital product teams with real business outcomes.
        </p>
        <a class="svc__link" href="services/">Learn more →</a>
      </article>
      <article class="svc" data-reveal>
        <div class="svc__num">02</div>
        <h3 class="svc__title">Digital Transformation</h3>
        <p class="svc__body">
          Accelerating delivery cadence, platform modernisation, and
          cross-functional operating model redesign — from quarterly to
          weekly release cycles.
        </p>
        <a class="svc__link" href="services/">Learn more →</a>
      </article>
      <article class="svc" data-reveal>
        <div class="svc__num">03</div>
        <h3 class="svc__title">Online Banking &amp; Digital Payments</h3>
        <p class="svc__body">
          Product design and go-to-market for mobile banking apps,
          payment gateway integrations, and fintech platforms across
          African markets.
        </p>
        <a class="svc__link" href="services/">Learn more →</a>
      </article>
    </div>
  </section>

  <!-- HOW HE WORKS ─────────────────────────────────────────────── -->
  <section class="section how">
    <div class="section__header" data-reveal>
      <div class="label">How it works</div>
      <h2>A clear process,<br>every time</h2>
    </div>

    <div class="how__steps">
      <div class="step" data-reveal>
        <span class="step__n">1</span>
        <div>
          <h3 class="step__t">Diagnose</h3>
          <p class="step__b">Understand the system as it actually works — not as it appears on paper.</p>
        </div>
      </div>
      <div class="step__arrow" aria-hidden="true">→</div>
      <div class="step" data-reveal>
        <span class="step__n">2</span>
        <div>
          <h3 class="step__t">Design</h3>
          <p class="step__b">Build the right interventions — roadmap, operating model, delivery cadence.</p>
        </div>
      </div>
      <div class="step__arrow" aria-hidden="true">→</div>
      <div class="step" data-reveal>
        <span class="step__n">3</span>
        <div>
          <h3 class="step__t">Deliver</h3>
          <p class="step__b">Embed, iterate, and hand off — with measurable outcomes that hold after he leaves.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW ──────────────────────────────────────────────── -->
  <section class="section about-preview">
    <div class="about-preview__inner">
      <div class="about-preview__left" data-reveal>
        <div class="label">About</div>
        <h2>Founder-led.<br>No junior consultants.</h2>
        <p>
          LeRoy Barnes is a Product Lead and Digital Business professional
          with a demonstrated history delivering large-scale digital
          solutions in banking, payments, and insurance across Africa.
        </p>
        <p>
          He works directly with founders and executive teams.
          No account managers, no padding.
        </p>
        <a class="btn btn--ghost" href="about/" style="margin-top: 24px;">About LeRoy →</a>
      </div>
      <div class="about-preview__right" data-reveal>
        <div class="credential">
          <div class="credential__label">Selected experience</div>
          <ul class="credential__list">
            <li>Pan-African digital payments — 10 markets</li>
            <li>Head of Digital, APA Insurance (Nairobi)</li>
            <li>Head of Product, Absa International Banking</li>
            <li>NovoFX mobile app + Western Union® at Absa</li>
          </ul>
        </div>
        <div class="credential" style="margin-top:24px">
          <div class="credential__label">Principles</div>
          <ul class="credential__list">
            <li>Strategy without delivery is just a slide deck</li>
            <li>Agile leadership — translate ambiguity into action</li>
            <li>Truthful metrics over vanity dashboards</li>
            <li>Products shipped beat roadmaps planned</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA ─────────────────────────────────────────────────── -->
  <section class="section cta-band">
    <div class="cta-band__inner" data-reveal>
      <div class="label">Get in touch</div>
      <h2>Let's talk about<br>your business.</h2>
      <p class="cta-band__sub">
        Briefly describe what you're trying to achieve.
        LeRoy responds within one to two business days.
      </p>
      <a class="btn btn--accent btn--lg" href="contact/">Start a conversation →</a>
    </div>
  </section>

</SiteLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────── */
  .hero { border-top: none; }
  .hero__label { margin-bottom: 20px; }
  .hero__h1 {
    font-size: var(--da-display);
    font-weight: 700;
    letter-spacing: var(--da-track-tight);
    line-height: var(--da-lead-tight);
    margin-bottom: 28px;
    max-width: 18ch;
  }
  .hero__sub {
    font-size: var(--da-body-lg);
    max-width: 56ch;
    color: var(--da-ink-muted);
    margin-bottom: 36px;
    line-height: 1.6;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: var(--da-gap);
  }

  /* Proof ribbon */
  .proof {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--da-line);
    padding-top: 36px;
    margin-top: 8px;
  }
  .proof__item { padding-right: 24px; }
  .proof__num {
    display: block;
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 800;
    letter-spacing: var(--da-track-tight);
    color: var(--da-accent);
    line-height: 1;
    margin-bottom: 6px;
  }
  .proof__text { font-size: 13px; color: var(--da-ink-muted); line-height: 1.4; }
  .proof__div { width: 1px; background: var(--da-line); margin: 0 24px 0 0; align-self: stretch; }

  /* ── Services ─────────────────────────────────────────────────── */
  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .svc {
    padding: 36px 32px 36px 0;
    border-right: 1px solid var(--da-line);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .svc:last-child { border-right: 0; padding-right: 0; }
  .svc:not(:first-child) { padding-left: 32px; }
  .svc__num {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--da-ink-faint);
    margin-bottom: 4px;
  }
  .svc__title {
    font-size: var(--da-h3);
    font-weight: 700;
    letter-spacing: var(--da-track-head);
    line-height: 1.25;
  }
  .svc__body { font-size: 14px; color: var(--da-ink-muted); line-height: 1.6; flex: 1; }
  .svc__link {
    font-size: 13px;
    font-weight: 600;
    color: var(--da-accent);
    margin-top: 4px;
    transition: opacity 0.15s;
  }
  .svc__link:hover { opacity: 0.7; }

  /* ── How ─────────────────────────────────────────────────────── */
  .how__steps { display: flex; align-items: flex-start; gap: 0; }
  .step { flex: 1; display: flex; gap: 16px; align-items: flex-start; }
  .step__n {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid var(--da-line-mid);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .step__t { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .step__b { font-size: 14px; color: var(--da-ink-muted); line-height: 1.55; }
  .step__arrow { font-size: 20px; color: var(--da-ink-faint); padding: 4px 20px 0; flex-shrink: 0; }

  /* ── About preview ────────────────────────────────────────────── */
  .about-preview { background: var(--da-surface); }
  .about-preview__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--da-gap);
  }
  .about-preview__left h2 {
    font-size: var(--da-h2);
    font-weight: 700;
    letter-spacing: var(--da-track-head);
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .about-preview__left p {
    font-size: 15px;
    color: var(--da-ink-muted);
    max-width: 44ch;
    margin-bottom: 14px;
    line-height: 1.65;
  }
  .credential__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--da-ink-faint);
    margin-bottom: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--da-line);
  }
  .credential__list { list-style: none; padding: 0; margin: 0; }
  .credential__list li {
    font-size: 14px;
    color: var(--da-ink-muted);
    padding: 8px 0;
    border-bottom: 1px solid var(--da-line);
    line-height: 1.4;
  }

  /* ── CTA band ─────────────────────────────────────────────────── */
  .cta-band { background: var(--da-ink); }
  .cta-band .label { color: rgba(255,255,255,0.45); }
  .cta-band__inner h2 {
    font-size: var(--da-h2);
    font-weight: 700;
    letter-spacing: var(--da-track-head);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 16px;
  }
  .cta-band__sub {
    font-size: var(--da-body);
    color: rgba(255,255,255,0.6);
    max-width: 50ch;
    margin-bottom: 32px;
    line-height: 1.6;
  }

  /* ── Responsive ──────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .proof { grid-template-columns: 1fr 1fr; gap: 24px; }
    .proof__div { display: none; }
    .services__grid { grid-template-columns: 1fr; }
    .svc { border-right: 0; border-bottom: 1px solid var(--da-line); padding: 28px 0; }
    .svc:last-child { border-bottom: 0; }
    .svc:not(:first-child) { padding-left: 0; }
    .how__steps { flex-direction: column; gap: 24px; }
    .step__arrow { display: none; }
    .about-preview__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .proof { grid-template-columns: 1fr 1fr; }
  }
</style>
